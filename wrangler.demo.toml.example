# Vivijure PUBLIC DEMO STUDIO -- wrangler config (#625). SEPARATE deploy from the studio core.
#
# This is the read-only, zero-spend public demo at demo.vivijure.com. It runs the SAME Worker code
# (src/index.ts) as the core, but AUTH_MODE=demo flips it to a browse-only projection: reads open to
# everyone, every mutation denied at the gate (src/auth-gate.ts verifyDemoRequest), and GET
# /api/modules advertises host.readonly = true. The catalog + content come entirely from a dedicated
# demo D1 seeded out of band (migrations/demo/0001_demo_seed.sql); no live module, GPU, or storage is
# reachable.
#
# account_id is NOT hardcoded; it is read from CLOUDFLARE_ACCOUNT_ID (env / CI secret), exactly like
# wrangler.toml.example. The real wrangler.demo.toml is gitignored and rendered from this example (or
# copied by hand, filling the one ${...} placeholder for a `wrangler deploy -c wrangler.demo.toml`).

name = "vivijure-demo"
main = "src/index.ts"
compatibility_date = "2026-06-01"
compatibility_flags = ["nodejs_compat"]

# No preview URLs, no workers.dev: the demo lives ONLY at its custom domain (below). A *.workers.dev
# hostname would be an unlabeled second door onto the same read-only surface -- keep it off.
preview_urls = false
workers_dev = false

# The studio frontend (public/) served via Workers Assets. IDENTICAL config to the core: the Worker
# owns ALL security headers, so every response (pages included) must route through the Worker's
# applyResponseSecurity chokepoint.
#   - run_worker_first = true: route every request through the Worker class (else the pages get NO
#     headers -- the post-v0.7.4 finding).
#   - html_handling = "none": serve assets at their EXACT path, no .html<->pretty-URL redirect loop
#     (the #374 -> #375 revert). The Worker maps the pretty page routes itself (STUDIO_PAGE_ASSETS).
# In demo mode applyResponseSecurity emits STUDIO_DEMO_CSP (asset-response.ts): the base studio CSP
# plus `media-src 'self' https://assets.skyphusion.net`, so the seeded showcase MP4s play.
assets = { directory = "./public", binding = "ASSETS", html_handling = "none", run_worker_first = true }

[observability]
enabled = true

# AUTH_MODE = "demo" is EXPLICIT and load-bearing. The deploy fails loud when AUTH_MODE is unset (the
# gate fails closed on an unknown mode, v0.12.1), and demo mode is the ENTIRE point of this deploy:
#   - src/auth-gate.ts isDemoMode -> reads open, writes denied with the "demo studio is read-only" reason;
#   - src/index.ts /api/modules -> host.readonly = true;
#   - src/modules/registry.ts isDemoEnv -> reads the seeded installed_modules rows with NO dispatch namespace;
#   - src/asset-response.ts -> STUDIO_DEMO_CSP (the showcase media-src).
# NEVER default this elsewhere; a demo deploy is demo mode or it is nothing.
[vars]
AUTH_MODE = "demo"

# --- Phase B (#631) render + assistant knobs. Absent/off => the demo stays Phase-A read-only (renders
# paused, no assistant). Fill + provision the paired bindings below at Phase B rollout (rider: infra
# mints creds, never CI). ---
# DEMO_RENDER_ENABLED "true" arms the seeded click-to-render menu; it ALSO needs MODULE_LOCAL_GPU bound
# (below). Unset/"false" => host.render.available=false => the UI shows "renders paused" (the box dies
# ~2026-08-04; flip this off to park renders with no demo outage).
DEMO_RENDER_ENABLED = "false"
# The ISOLATED demo R2 public origin the box writes clips under; the demo serves <origin>/<clip_key>
# (the demo worker binds NO R2). Enumerated in the demo media CSP. Keep it under assets.skyphusion.net
# so the existing STUDIO_DEMO_CSP media-src already admits it (no CSP change needed); a distinct origin
# is added to media-src automatically (asset-response.ts), still no wildcard.
DEMO_ARTIFACT_ORIGIN = "https://assets.skyphusion.net"
# The OSS assistant model + optional cap overrides (defaults: 3 renders/IP/day, 2000 global; 20 chats/IP,
# 2000 global; queue depth 10). Tune without a code change.
DEMO_ASSISTANT_MODEL = "@cf/meta/llama-3.3-70b-instruct-fp8-fast"
# DEMO_RENDER_PER_IP_DAILY = "3"
# DEMO_RENDER_GLOBAL_DAILY = "2000"
# DEMO_RENDER_QUEUE_DEPTH = "10"
# DEMO_CHAT_PER_IP_DAILY = "20"
# DEMO_CHAT_GLOBAL_DAILY = "2000"
# Fail-closed spend limiter posture is the default; the demo render route uses SPEND_RATE_LIMITER for the
# per-IP burst check, so that binding MUST be present when DEMO_RENDER_ENABLED="true" (a broken/unbound
# limiter denies renders 503, which is the correct money-path posture).

# The dedicated DEMO D1 (binding name DB). Provision + seed OUT OF BAND, NEVER touching prod:
#   wrangler d1 create vivijure-demo                                    # paste the id below / into CI var
#   wrangler d1 migrations apply vivijure-demo --remote                 # base schema migrations/0001..0010
#   wrangler d1 execute vivijure-demo --remote --file=migrations/demo/0001_demo_seed.sql   # the seed (idempotent)
#   wrangler d1 execute vivijure-demo --remote --file=migrations/demo/0002_demo_render.sql   # Phase B: menu + queue + counters (idempotent)
# The seed's render rows carry ABSOLUTE assets.skyphusion.net URLs, so the demo needs NO R2 binding to
# display a film. database_id is rendered from D1_DEMO_DATABASE_ID (CI) or filled by hand.
[[d1_databases]]
binding = "DB"
database_name = "vivijure-demo"
database_id = "${D1_DEMO_DATABASE_ID}"

# --- Phase B (#631) bindings: EXACTLY the two bounded spend paths, provisioned + filled at rollout. ---
# Until provisioned, leave these OUT: the demo runs Phase A (render paused, no assistant), fully valid.
#
# (a) The render path -- the ONE new outbound: a DEMO-SCOPED local-gpu door worker holding the box's
#     stable NAMED-tunnel LOCAL_BACKEND_URL + a REGENERATED demo LOCAL_BACKEND_TOKEN (minted by infra;
#     values never in CI). The demo core reaches it as MODULE_LOCAL_GPU; the box reads the seeded
#     keyframe from the ISOLATED demo R2 prefix and writes the clip there -> a public DEMO_ARTIFACT_ORIGIN
#     URL. The demo core binds NO R2, NO presign creds, NO CPU-container VPCs.
# [[services]]
# binding = "MODULE_LOCAL_GPU"
# service = "vivijure-demo-local-gpu"   # the demo-scoped local-gpu worker (its own deploy, demo box creds)
#
# (b) The assistant -- an OSS model behind its OWN hard-capped AI Gateway (GATEWAY_ID = the DEMO gateway,
#     a Secrets Store secret; the gateway config carries the HARD daily budget). Per-IP + global daily
#     caps are enforced in D1 (demo_counter) BEFORE the model is called.
# [ai]
# binding = "AI"
# [[secrets_store_secrets]]
# binding = "GATEWAY_ID"
# store_id = "REPLACE_WITH_VIVIJURE_SECRETS_STORE_ID"
# secret_name = "DEMO_GATEWAY_ID"
#
# (c) The per-IP BURST limiter for the render route (constraint 4). Its namespace id is provisioned by
#     infra; the daily submission caps live in demo_counter (above), this is the short-window burst gate.
# [[ratelimits]]
# name = "SPEND_RATE_LIMITER"
# namespace_id = "${DEMO_SPEND_RATE_LIMITER_NS_ID}"
# simple = { limit = 6, period = 60 }

# --- STILL DELIBERATELY ABSENT -- the ABSENCE is the (now BOUNDED-spend) proof, do NOT add any of these. ---
#
# Phase B keeps the two spend families disjoint and everything else absent:
#   * NO RUNPOD_API_KEY / RUNPOD_ENDPOINT_ID -- no datacenter GPU; RunPod spend is zero BY ABSENCE.
#   * NO frontier BYOK keys (XAI_API_KEY / OPENAI_API_KEY / CF_AIG_TOKEN for a frontier model) -- the
#     assistant is OSS-only; metered frontier tokens are unreachable.
#   * NO R2 buckets (R2 / R2_RENDERS) and NO R2_S3_* presign creds -- the box owns the render bytes to an
#     isolated public prefix; the demo only string-builds the public URL.
#   * NO CPU-container VPCs (VIDEO_FINISH_VPC / IMAGE_PREP_VPC / AUDIO_BEAT_SYNC_VPC / AUDIO_MIX_VPC) --
#     Phase B renders ONE i2v clip, no assemble/mux.
#   * NO MODULE_DISPATCH namespace and NO OTHER MODULE_* service binding -- the catalog stays the seeded
#     rows; ONLY the local-gpu door is reachable, so no other GPU/paid backend can be invoked.
#   * NO cron [triggers] (the render advances on GET-poll), NO tail consumer, NO STUDIO_API_TOKEN.
#
# If boot/deploy demands one of the absent bindings, that is a BLOCKER to escalate -- NOT a binding to add.

# demo.vivijure.com on the vivijure.com zone. Workers custom domain owns DNS + the cert (Universal SSL
# for a first-level subdomain -- NO Advanced Certificate Manager needed).
[[routes]]
pattern = "demo.vivijure.com"
custom_domain = true
