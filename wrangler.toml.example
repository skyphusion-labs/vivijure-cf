# Vivijure studio core -- wrangler config.
#
# account_id is NOT hardcoded; it is read from CLOUDFLARE_ACCOUNT_ID (set in .dev.vars locally, or
# injected as a secret in CI). Mirror every binding change in src/env.ts (the hand-authored Env).

name = "vivijure-studio"
main = "src/index.ts"
compatibility_date = "2026-06-01"
compatibility_flags = ["nodejs_compat"]

# Disable preview urls
preview_urls = false

# workers.dev route DISABLED (security F1): the *.workers.dev hostname is NOT covered by CF Access
# (Access reliably gates only custom/zone-proxied domains), so leaving it on exposed the entire /api
# UNAUTHENTICATED. Legit access is vivijure.skyphusion.org behind Access. Conrad confirmed the route
# is not needed. Re-enabling requires an in-Worker auth gate that does not depend on the edge Access app.
workers_dev = false

# The studio frontend (public/) served via Workers Assets.
#
# The Worker owns ALL security headers (CF managed-transform header layer is OFF), so EVERY response
# -- including the static HTML pages -- must run through the Worker's applyResponseSecurity chokepoint:
#   - run_worker_first = true: route every request (pages + sub-resources) through the Worker class.
#     Without it, Workers Assets serves the pages straight from the edge, BYPASSING the Worker, so
#     the static pages get NO headers (the post-v0.7.4 finding).
#   - html_handling = "none": serve assets at their EXACT path with NO .html<->pretty-URL redirects.
#     This is the load-bearing half: with the default handling, serveStudioAsset's env.ASSETS.fetch
#     of /planner.html 307-redirects back to /planner -> redirect loop -> blank page (the #374 -> #375
#     revert). "none" makes that fetch return the real file (200), and the Worker maps the pretty page
#     routes itself (STUDIO_PAGE_ASSETS, incl. "/" -> /modules.html). Dev-verified, no loop.
assets = { directory = "./public", binding = "ASSETS", html_handling = "none", run_worker_first = true }

# >>> SELFHOST-SKIP: tail-consumer -- core render logs -> Loki/Grafana via OUR vivijure-tail worker
# Tail consumer -- ships core render logs + exceptions to vivijure-tail -> Loki -> Grafana.
# DEPLOY-ORDERED: vivijure-tail must be live BEFORE this binding deploys (dangling-binding hazard).
tail_consumers = [ { service = "vivijure-tail" } ]
# <<< SELFHOST-SKIP: tail-consumer

# Auth for /api/* (#423, src/auth-gate.ts). AUTH_MODE picks the gate:
#   "token"  -> built-in bearer token: /api/* requires Authorization: Bearer <token> checked
#               against the STUDIO_API_TOKEN worker SECRET (deploy.sh mints + stores it; it is
#               never a var). No Zero Trust product needed; leave the ACCESS_* vars empty.
#   "access" -> in-Worker CF Access JWT verification (F2, defense-in-depth BEHIND an edge Access
#               app). Requires ACCESS_TEAM_DOMAIN + ACCESS_AUD -- public Zero-Trust identifiers
#               (team hostname + the vivijure app AUD), not secrets.
# Fail closed: an unknown mode, or token mode without its secret, denies every /api/* request.
[vars]
AUTH_MODE = "${AUTH_MODE}"
ACCESS_TEAM_DOMAIN = "${ACCESS_TEAM_DOMAIN}"
ACCESS_AUD = "${ACCESS_AUD}"
# R2 S3-API presign identifiers (src/r2-presign.ts). NOT secrets: R2_S3_ENDPOINT is the public
# account-scoped R2 S3 host (https://<account-id>.r2.cloudflarestorage.com), R2_S3_BUCKET is the
# same `vivijure` bucket bound as R2_RENDERS below. Both are deploy-injected (ci.yml / deploy.sh)
# from CLOUDFLARE_ACCOUNT_ID -- the same value wrangler already uses -- so neither needs a Secrets
# Store entry (#238 follow-up; they are identifiers, not secrets).
R2_S3_ENDPOINT = "${R2_S3_ENDPOINT}"
R2_S3_BUCKET = "${R2_S3_BUCKET}"
# S4/S9 spend-posture knobs (src/rate-limit.ts):
#   SPEND_LIMIT_FAIL_CLOSED -- fail-CLOSED by DEFAULT (S9 F7): when the spend limiter is BROKEN
#     (SPEND_RATE_LIMITER unbound, or .limit()/the daily-ceiling check throws) the spend routes are
#     DENIED 503, not allowed -- the money path fails closed like the auth gate, so a novice never
#     silently runs unmetered. A healthy limiter (bound below) is unaffected. Set to the literal
#     "false" to opt back to fail-open (a limiter blip allows the render).
#   SPEND_DAILY_CEILING = "25"        -- OFF unless set: at most N spend-route submissions per UTC day
#     (counted in D1, migration 0008). Over the ceiling returns 429 until UTC midnight. Submissions,
#     not dollars.
# SPEND_LIMIT_FAIL_CLOSED = "false"
# SPEND_DAILY_CEILING = "25"
# Assemble duration honesty gate (#697, src/film-orchestrator.ts):
#   FILM_CLIP_DURATION_FLOOR -- the fraction of a shot`s PLANNED seconds its ASSEMBLED clip must reach
#     before the render FAILS LOUD (a truncated per-shot finish output, not a legitimate beat-trim; the
#     pixel gate #558 checks content, not length). Default 0.5, clamped to [0,1]; "0" disables the gate.
#     The gate arms only once video-finish returns per-clip durations (see containers/video-finish); an
#     older container reports none and the gate no-ops (logged, never a false failure).
# FILM_CLIP_DURATION_FLOOR = "0.5"

[observability]
enabled = true

[triggers]
crons = ["*/1 * * * *"]

# AI Gateway (LLM storyboard planning + cloud-animate scoring). GATEWAY_ID + CF_AIG_TOKEN are
# Cloudflare Secrets Store secrets (see the [[secrets_store_secrets]] blocks below), seeded once by
# the operator; their values never touch CI/GitHub.
[ai]
binding = "AI"

# Spend rate-limit (Workers Rate Limiting, GA) -- F3. Enforced in-Worker on the GPU-spend trigger
# path (#343); bound here by infra so the limiter exists before the code arms it. ~30 req / 60s.
# The TS interface (SPEND_RATE_LIMITER?: RateLimitBinding) + enforcement land in #343 (Rollins);
[[ratelimits]]
name = "SPEND_RATE_LIMITER"
namespace_id = "${SPEND_RATE_LIMITER_NS_ID}"
simple = { limit = 30, period = 60 }

# Storage. R2_RENDERS = the `vivijure` bucket (bundles, keyframes, clips, MP4s, project state).
# R2 = the chat-side `skyphusion-llm` bucket the render flow copies a staged audio bed across from.
# (Transition coupling: revisit moving the audio bed onto R2_RENDERS for a fully standalone studio.)
[[r2_buckets]]
binding = "R2_RENDERS"
bucket_name = "vivijure"

[[r2_buckets]]
binding = "R2"
bucket_name = "skyphusion-llm"

# Fresh, dedicated D1 (no migration of legacy playground data).
# Provision + apply the schema of record:
#   npx wrangler d1 create vivijure-studio        # paste the returned id below
#   npx wrangler d1 migrations apply vivijure-studio   # applies migrations/0001_init.sql
[[d1_databases]]
binding = "DB"
database_name = "vivijure-studio"
database_id = "${D1_DATABASE_ID}"

# --- Off-GPU CPU work runs always-on on the fleet (issue #83), reached privately over Workers VPC
# --- (see [[vpc_services]] below). The CF Container + its Durable Object class were removed once the
# --- VPC path was validated end-to-end in prod (clears #64, #82). Build contexts for the 3 images
# --- live in containers/<name>/ and now run as always-on Docker via containers/compose.yaml.

# Migration history: v1 created the video-finish container DO class; v2 drops it (off CF Containers).
[[migrations]]
tag = "v1-video-finish"
new_sqlite_classes = ["VideoFinishContainer"]

[[migrations]]
tag = "v2-drop-cpu-containers"
# A migration chain may only delete classes THIS config history created. The v1 migration above
# declares only VideoFinishContainer, so on a fresh account the other two classes never existed and
# deleting them hard-fails the deploy (API code 10074). Prod created all three in its real history;
# an outsider deploying from this example does not.
deleted_classes = ["VideoFinishContainer"]

# Workers VPC -> the media-stack CPU containers (video-finish / image-prep / audio-beat-sync /
# audio-mix) run always-on on the operator's own container host (containers/compose.yaml),
# reached over private VPC bindings. STANDARD as of #519: deploy.sh creates the tunnel + these
# VPC services and renders their ids here, so there is nothing to strip (issue #83 -- off CF
# Containers, no cold start).
[[vpc_services]]
binding = "VIDEO_FINISH_VPC"
service_id = "${VPC_VIDEO_FINISH_ID}"
remote = true

[[vpc_services]]
binding = "IMAGE_PREP_VPC"
service_id = "${VPC_IMAGE_PREP_ID}"
remote = true

[[vpc_services]]
binding = "AUDIO_BEAT_SYNC_VPC"
service_id = "${VPC_AUDIO_BEAT_SYNC_ID}"
remote = true
# max_instances = 5

[[vpc_services]]
binding = "AUDIO_MIX_VPC"
service_id = "${VPC_AUDIO_MIX_ID}"
remote = true

# --- Credential secrets via the Cloudflare Secrets Store (#238). Seeded ONCE by the operator
# --- (npx wrangler secrets-store secret create <STORE_ID> --name <NAME> ...); values never touch
# --- CI/GitHub. store_id is filled from the SECRETS_STORE_ID repo variable at deploy (ci.yml),
# --- exactly like the module workers. See docs/DEPLOYMENT.md.
# --- NOTE: binding RUNPOD_ENDPOINT_ID reads store secret BACKEND_RUNPOD_ENDPOINT_ID (#237 naming);
# --- the core CF_AIG_TOKEN is its OWN store secret, distinct from the module PLAN_ENHANCE_CF_AIG_TOKEN.
[[secrets_store_secrets]]
binding = "RUNPOD_API_KEY"
store_id = "REPLACE_WITH_VIVIJURE_SECRETS_STORE_ID"
secret_name = "RUNPOD_API_KEY"

[[secrets_store_secrets]]
binding = "RUNPOD_ENDPOINT_ID"
store_id = "REPLACE_WITH_VIVIJURE_SECRETS_STORE_ID"
secret_name = "BACKEND_RUNPOD_ENDPOINT_ID"

# Dedicated Wan 2.2 A14B LoRA-training endpoint (cast /train-wan-lora, cf#29). OPTIONAL: a deploy
# without Wan training omits it and handleCastTrainWanLora fails loud if the route is hit unset.
[[secrets_store_secrets]]
binding = "RUNPOD_WAN_TRAIN_ENDPOINT_ID"
store_id = "REPLACE_WITH_VIVIJURE_SECRETS_STORE_ID"
secret_name = "BACKEND_RUNPOD_WAN_TRAIN_ENDPOINT_ID"

[[secrets_store_secrets]]
binding = "GATEWAY_ID"
store_id = "REPLACE_WITH_VIVIJURE_SECRETS_STORE_ID"
secret_name = "GATEWAY_ID"

[[secrets_store_secrets]]
binding = "CF_AIG_TOKEN"
store_id = "REPLACE_WITH_VIVIJURE_SECRETS_STORE_ID"
secret_name = "CF_AIG_TOKEN"

[[secrets_store_secrets]]
binding = "R2_S3_ACCESS_KEY_ID"
store_id = "REPLACE_WITH_VIVIJURE_SECRETS_STORE_ID"
secret_name = "R2_S3_ACCESS_KEY_ID"

[[secrets_store_secrets]]
binding = "R2_S3_SECRET_ACCESS_KEY"
store_id = "REPLACE_WITH_VIVIJURE_SECRETS_STORE_ID"
secret_name = "R2_S3_SECRET_ACCESS_KEY"

# --- Non-secret / operator-provided values that stay OUT of the Secrets Store:
# ---   R2_S3_ENDPOINT + R2_S3_BUCKET : identifiers (URL + bucket name), now rendered into [vars]
# ---     above from CLOUDFLARE_ACCOUNT_ID at deploy (#238 follow-up) -- NOT wrangler secrets.
# ---   STUDIO_API_TOKEN : operator login, deploy-minted worker secret (openssl rand | wrangler secret put).
# ---   XAI_API_KEY / OPENAI_API_KEY : optional BYOK; leave as `wrangler secret put` when used.

# --- Render-complete notification = the `notify` hook + the notify-email module (MODULE_NOTIFY_EMAIL
# --- below), NOT a core binding. Notification is multi-backend (email / webhook / ...), so it's a
# --- module: the core fires the `notify` chain on the done-transition; each notifier delivers.

# --- Opt-in MODULE workers: service bindings named MODULE_<NAME>; the registry discovers them.
[[services]]
binding = "MODULE_PLANENHANCE"
service = "vivijure-module-plan-enhance"

# Own-GPU i2v (Wan2.2 via the vivijure-backend RunPod endpoint): the BYO-GPU default motion.backend.
[[services]]
binding = "MODULE_OWN_GPU"
service = "vivijure-module-own-gpu"

# >>> LOCAL-GPU: local-gpu -- i2v on the operator's OWN local GPU box (opt-in)
#     deploy.sh strips this unless INSTALL_LOCAL_GPU=1: the local-gpu module is only
#     deployed when you have a local backend, so binding it before then would dangle
#     (code 10143). CI keeps it (prod binds the deployed module). See docs/DEPLOYMENT.md.
# Local-consumer i2v (LTX-Video on a disposable RunPod SECURE pod running vivijure-local-12gb, exposed
# via a named Cloudflare tunnel (production fleet: door-fatmike.skyphusion.org on fatmike): the LOCAL
# door. LOCAL_BACKEND_URL is seeded in the Secrets Store (see deploy.env.example); bind ONLY after
# local-gpu is un-excluded + deployed (flip 1/2) and LOCAL_BACKEND_URL / LOCAL_BACKEND_TOKEN are
# seeded in the Secrets Store, else this [[services]] target dangles.
[[services]]
binding = "MODULE_LOCAL_GPU"
service = "vivijure-module-local-gpu"
# <<< LOCAL-GPU: local-gpu

[[services]]
binding = "MODULE_SEEDANCE"
service = "vivijure-module-seedance"

[[services]]
binding = "MODULE_KLING"
service = "vivijure-module-kling"

[[services]]
binding = "MODULE_KEYFRAME"
service = "vivijure-module-keyframe"

[[services]]
binding = "MODULE_FINISH_RIFE"
service = "vivijure-module-finish-rife"

# >>> SATELLITE: finish-upscale -- Real-ESRGAN upscale on a SEPARATE RunPod endpoint
# Upscale: a finish-chain module (Real-ESRGAN 2x/4x spatial upscale) on the dedicated vivijure-upscale
# RunPod endpoint (CUDA, separate from vivijure-backend). Folds after finish-rife in ui.order.
[[services]]
binding = "MODULE_UPSCALE"
service = "vivijure-module-finish-upscale"
# <<< SATELLITE: finish-upscale

# Film titles: a film.finish-chain module (opening title + end credit cards) that runs on the
# assembled+muxed film via the video-finish /film-titles route. The orchestrator invokes the
# film.finish chain (applyFilmFinish, post-mux before done) since v0.3.0, so this runs on every
# single-film render; discovered by the registry.
[[services]]
binding = "MODULE_FILM_TITLES"
service = "vivijure-module-film-titles"

# Cast.image: generate a character's LoRA training reference set (FLUX 2 / Nano Banana). Cast-prep.
[[services]]
binding = "MODULE_CAST_IMAGE"
service = "vivijure-module-cast-image"

# Image.generate: prompt -> one image, for the chat image path and the cast portrait preview.
# LOAD-BEARING for the image catalog, not an optional extra: the core hardcodes no image model names
# (cf#129 phase 2), so GET /api/models projects its image rows from THIS module's manifest. Unbound,
# the image catalog is honestly empty and the picker offers nothing.
[[services]]
binding = "MODULE_IMAGE_GENERATE"
service = "vivijure-module-image-generate"

# Notify (render-complete): the email backend of the `notify` hook -- native CF Email Service.
[[services]]
binding = "MODULE_NOTIFY_EMAIL"
service = "vivijure-module-notify-email"

# Music generation: MiniMax Music 2.6 via Workers AI + AI Gateway (planner audio bed).
[[services]]
binding = "MODULE_MUSIC_GEN"
service = "vivijure-module-music-gen"

# Narration: MiniMax Speech 2.8 HD via Workers AI + AI Gateway (score chain).
[[services]]
binding = "MODULE_NARRATION_GEN"
service = "vivijure-module-narration-gen"

# Beat sync: librosa analysis via fleet audio-beat-sync container (score chain, VPC).
[[services]]
binding = "MODULE_BEAT_SYNC"
service = "vivijure-module-beat-sync"

# Audio master: film-level mastering of the assembled audio bed (music upscale + LUFS loudness) on the
# audio-master CPU VPC container (containers/audio-master over AUDIO_MASTER_VPC -- CPU ffmpeg, NEVER
# RunPod/GPU). The `master` chain runs after assemble, before the final mux; a master miss soft-degrades
# to the un-mastered bed (never fails the render).
[[services]]
binding = "MODULE_AUDIO_MASTER"
service = "vivijure-module-audio-master"

# Dialogue: per-shot spoken lines -> Deepgram Aura-1 (Workers AI) in the cast member's voice. The
# `dialogue` phase runs after clips, before finish; its audio_key feeds the lip-sync finish module.
[[services]]
binding = "MODULE_DIALOGUE"
service = "vivijure-module-dialogue-gen"

# >>> SATELLITE: finish-lipsync -- MuseTalk lip-sync on a SEPARATE RunPod endpoint
# Lip-sync (finish chain): MuseTalk on the dedicated cu128 RunPod endpoint; rewrites a shot's mouth
# to the dialogue audio_key. Runs before the upscaler (ui.order 15 < 20).
[[services]]
binding = "MODULE_LIPSYNC"
service = "vivijure-module-finish-lipsync"
# <<< SATELLITE: finish-lipsync

# >>> SATELLITE: speech-upscale -- speech cleanup on a SEPARATE RunPod endpoint
# Speech upscale (the `speech` hook): aviation-grade speech cleanup / enhancement on the dialogue
# audio_key before lip-sync consumes it. Its own per-module worker; the registry discovers it as a
# MODULE_* binding.
[[services]]
binding = "MODULE_SPEECH_UPSCALE"
service = "vivijure-module-speech-upscale"
# <<< SATELLITE: speech-upscale

# Cloud i2v motion.backend modules (RunPod-hosted), joining own-gpu / seedance / kling. Each is its
# own per-module worker with a scoped RUNPOD_API_KEY; the registry discovers them as MODULE_* bindings.
# These deploy ahead of the core (see ci.yml), so the bindings never dangle.
[[services]]
binding = "MODULE_MINIMAX_HAILUO"
service = "vivijure-module-minimax-hailuo"

[[services]]
binding = "MODULE_GOOGLE_VEO"
service = "vivijure-module-google-veo"

[[services]]
binding = "MODULE_VIDU_Q3"
service = "vivijure-module-vidu-q3"

[[services]]
binding = "MODULE_ALIBABA_WAN"
service = "vivijure-module-alibaba-wan"

# alibaba-wan-lora: Wan 2.2 i2v 720p on the RunPod PUBLIC managed endpoint wan-2-2-t2v-720-lora, with
# CUSTOM operator LoRAs (the controllable, GPU-rental-free i2v lane; pairs with the cloud-keyframe
# module). A motion.backend module, discovered by the registry exactly like any MODULE_* binding.
#
# Re-listed 2026-07-22 after 2x2 dual-panel Wan LoRA sign-off (cf#29 / fleet runlog
# 2026-07-21-vivijure-wan-train-2x2-signoff.md). Binding must stay uncommented so tag deploys
# do not drop the live MODULE_ALIBABA_WAN_LORA service binding.
[[services]]
binding = "MODULE_ALIBABA_WAN_LORA"
service = "vivijure-module-alibaba-wan-lora"

# Cloud keyframe (GPUless cost-door): FLUX-2 direct on the AI binding + nano-banana-pro via AI Gateway.
# ADDED in v0.3.0.
[[services]]
binding = "MODULE_CLOUD_KEYFRAME"
service = "vivijure-module-cloud-keyframe"

# Subtitle (film.finish): burns a time-synced SRT via the video-finish container (POST /subtitle).
# ADDED in v0.3.0; depends on the video-finish container rebuild (runbook 1.0).
[[services]]
binding = "MODULE_SUBTITLE"
service = "vivijure-module-subtitle"

# --- Phase 3: Workers for Platforms (WfP) dynamic dispatch -- OPT-IN, ships COMMENTED OUT on purpose.
# ---
# --- LEAVE IT COMMENTED for a standard self-host: modules bind as [[services]] (above) and everything
# --- works with ZERO WfP dependency. Dispatch is an OPERATOR CONVENIENCE (install a module WITHOUT a
# --- core redeploy), NEVER a requirement to run vivijure. The core dispatch layer is runtime-gated on
# --- MODULE_DISPATCH being bound, so absent it the behavior is identical.
# ---
# --- Uncomment the block below ONLY if you have BOTH (1) enabled Workers for Platforms on your
# --- Cloudflare account (a PAID add-on) and (2) created the `vivijure-modules` dispatch namespace out
# --- of band (see docs/deploy-runbook.md "Phase 3: create the dispatch namespace"). A
# --- [[dispatch_namespaces]] binding is subject to the dangling-binding rule: the namespace must EXIST
# --- at deploy time or `wrangler deploy` of the core FAILS -- so shipping it ACTIVE on an account
# --- without WfP would break the deploy (and the free-self-host promise). That is why it stays
# --- COMMENTED here: the committed template is free-self-host-safe by default.
# ---
# --- How OUR prod turns it on WITHOUT editing this template: the CI "Render core wrangler.toml" step
# --- uncomments exactly these three lines when the repo VARIABLE `ENABLE_WFP_DISPATCH` == "1" (set
# --- only on the account that created the namespace). A community fork never sets that variable, so
# --- its render leaves this block commented. A manual self-host that DOES want WfP just uncomments
# --- these lines by hand after creating the namespace.
# ---
# --- When enabled, the core becomes the OUTBOUND dynamic-dispatch Worker for `vivijure-modules`; a
# --- module uploaded into that namespace is reached at request time via
# --- env.MODULE_DISPATCH.get(<script>).fetch(...), with no core redeploy. Mirror the binding in
# --- src/env.ts (MODULE_DISPATCH?: DispatchNamespace).
# [[dispatch_namespaces]]
# binding = "MODULE_DISPATCH"
# namespace = "vivijure-modules"
#
# # OPTIONAL hardening (deferred, see docs/module-dispatch.md section 7): an OUTBOUND worker can
# # intercept every outbound fetch a module makes (egress allow-list, spend metering). Wire it only when
# # that worker exists, or the core deploy fails on a dangling outbound reference. Left disabled until
# # vivijure-module-egress-guard is deployed.
# # outbound = { service = "vivijure-module-egress-guard" }

[[routes]]
pattern = "vivijure.skyphusion.org"
custom_domain = true

