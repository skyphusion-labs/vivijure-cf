{
  "name": "vivijure-cf",
  "version": "1.0.0",
  "description": "Vivijure Studio Cloudflare control panel: Workers host on @skyphusion-labs/vivijure-core. Pair with vivijure-local for self-hosted.",
  "license": "AGPL-3.0-only",
  "homepage": "https://vivijure.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/skyphusion-labs/vivijure-cf.git"
  },
  "keywords": [
    "ai-video",
    "filmmaking",
    "cloudflare-workers",
    "vivijure",
    "agpl"
  ],
  "type": "module",
  "dependencies": {
    "@cloudflare/containers": "0.3.7",
    "@skyphusion-labs/vivijure-core": "^0.9.5",
    "@skyphusion-labs/vivijure-mcp": "^0.1.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:mcp": "wrangler dev -c wrangler.mcp.toml",
    "deploy": "wrangler deploy",
    "deploy:mcp": "wrangler deploy -c wrangler.mcp.toml",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "conformance": "vitest run tests/conformance.test.ts tests/conformance.live.test.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
